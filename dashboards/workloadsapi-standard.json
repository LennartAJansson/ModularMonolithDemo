{
  "title": "workloadsapi - Standard Metrics",
  "uid": "workloadsapi-standard",
  "tags": [ "workloadsapi", "api", "dotnet", "efcore", "redis" ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_time_seconds_total{namespace=\"workloadsapi\"}[5m]) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_memory_usage_bytes{namespace=\"workloadsapi\"} / 1024 / 1024",
          "legendFormat": "Physical Memory MB"
        },
        {
          "expr": "process_memory_virtual_bytes{namespace=\"workloadsapi\"} / 1024 / 1024 / 1024",
          "legendFormat": "Virtual Memory GB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Response Times (P50, P95, P99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_server_request_duration_seconds_bucket{namespace=\"workloadsapi\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket{namespace=\"workloadsapi\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_request_duration_seconds_bucket{namespace=\"workloadsapi\"}[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "{{http_status_code}} - {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "ASP.NET Core - Active Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "http_server_active_requests{namespace=\"workloadsapi\"}",
          "legendFormat": "Active Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 7,
      "title": ".NET GC Collections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(dotnet_gc_collections_total{namespace=\"workloadsapi\",gc_heap_generation=\"gen0\"}[5m])",
          "legendFormat": "Gen 0"
        },
        {
          "expr": "rate(dotnet_gc_collections_total{namespace=\"workloadsapi\",gc_heap_generation=\"gen1\"}[5m])",
          "legendFormat": "Gen 1"
        },
        {
          "expr": "rate(dotnet_gc_collections_total{namespace=\"workloadsapi\",gc_heap_generation=\"gen2\"}[5m])",
          "legendFormat": "Gen 2"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": ".NET Thread Pool",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "dotnet_thread_pool_thread_count_total{namespace=\"workloadsapi\"}",
          "legendFormat": "Thread Count"
        },
        {
          "expr": "dotnet_thread_pool_queue_length_total{namespace=\"workloadsapi\"}",
          "legendFormat": "Queue Length"
        },
        {
          "expr": "process_thread_count{namespace=\"workloadsapi\"}",
          "legendFormat": "Total Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "title": "EF Core - Queries per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(microsoft_entityframeworkcore_queries_total{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "Queries/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 10,
      "title": "EF Core - SaveChanges per Second",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(microsoft_entityframeworkcore_savechanges_total{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "SaveChanges/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 11,
      "title": "EF Core - Failures",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(microsoft_entityframeworkcore_optimistic_concurrency_failures_total{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "Concurrency Failures/sec"
        },
        {
          "expr": "rate(microsoft_entityframeworkcore_execution_strategy_operation_failures_total{namespace=\"workloadsapi\"}[5m])",
          "legendFormat": "Retry Failures/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 12,
      "title": "EF Core - Active DbContexts",
      "type": "stat",
      "gridPos": { "x": 12, "y": 40, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "microsoft_entityframeworkcore_active_dbcontexts{namespace=\"workloadsapi\"}",
          "legendFormat": "Active DbContexts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "EF Core - Query Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 40, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 * (rate(microsoft_entityframeworkcore_compiled_query_cache_hits_total{namespace=\"workloadsapi\"}[5m]) / (rate(microsoft_entityframeworkcore_compiled_query_cache_hits_total{namespace=\"workloadsapi\"}[5m]) + rate(microsoft_entityframeworkcore_compiled_query_cache_misses_total{namespace=\"workloadsapi\"}[5m])))",
          "legendFormat": "Cache Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 80, "color": "yellow" },
              { "value": 95, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Redis - Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 48, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "max(up{job=\"redis\"})",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Redis - Connected Clients",
      "type": "stat",
      "gridPos": { "x": 8, "y": 48, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "max(redis_connected_clients{job=\"redis\"})",
          "legendFormat": "clients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 16,
      "title": "Redis - Memory Used",
      "type": "stat",
      "gridPos": { "x": 16, "y": 48, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "max(redis_memory_used_bytes{job=\"redis\"}) / 1024 / 1024",
          "legendFormat": "MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "thresholds" }
        }
      }
    }
  ]
}


